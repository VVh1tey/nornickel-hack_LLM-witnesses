# Скопируй в .env и заполни. .env в .gitignore — ключи в git не попадают.

# LLM: ollama (локальный Qwen, по умолчанию) | yandex
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
RERANK_MODEL=dengcao/Qwen3-Reranker-0.6B:Q8_0
# потолок длины ответа модели в токенах — защита от срыва в галлюцинацию
# вместо короткого JSON (проверено на реальном прогоне: 213КБ вместо {"a":1})
OLLAMA_NUM_PREDICT=4096

YC_FOLDER_ID=b1g...
YC_API_KEY=AQVN...
# модель для генерации/экстракции: pro, не lite — качество экстракции определяет граф
YC_MODEL=yandexgpt

# эмбеддинги: local (bge-m3, по умолчанию) | yandex (text-embeddings-v2, doc/query)
EMBEDDING_PROVIDER=local
# EMBEDDING_DIM=768   # только для EMBEDDING_PROVIDER=yandex (128/256/512/768)

# векторный индекс LightRAG
QDRANT_URL=http://localhost:6333

# история сессий
POSTGRES_DSN=postgresql://hypofactory:hypofactory@localhost:5432/hypofactory

LLM_MAX_CONCURRENCY=4

# предметная область (см. backend/hypofactory/domain_profile.py) — параметризует
# entity_types LightRAG и формулировку "ты эксперт по..." в промптах
DOMAIN_PROFILE=obogashchenie

# авторизация API (см. api/app.py) — пусто = выключена (локальная разработка).
# Обязательно задать непустой ключ, если сервис смотрит дальше localhost.
# Сгенерировать: openssl rand -hex 24
API_KEY=

# HYPOFACTORY_FAKE_LLM=1   # форсировать FakeLLM/фейковые эмбеддинги независимо от провайдера

# ===== Langfuse (self-hosted, docker-compose.yml) — трейс вызовов LLM =====
# UI после `docker compose up langfuse-web`: http://localhost:3000
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGEME
LANGFUSE_SECRET_KEY=sk-lf-CHANGEME

# сгенерировать: openssl rand -hex 16 / 32 / 12 (см. README)
LANGFUSE_SALT=CHANGEME
LANGFUSE_ENCRYPTION_KEY=CHANGEME
LANGFUSE_NEXTAUTH_SECRET=CHANGEME
LANGFUSE_PG_PASSWORD=CHANGEME
LANGFUSE_CLICKHOUSE_PASSWORD=CHANGEME
LANGFUSE_MINIO_PASSWORD=CHANGEME
LANGFUSE_REDIS_AUTH=CHANGEME
LANGFUSE_INIT_USER_EMAIL=admin@hypofactory.local
LANGFUSE_INIT_USER_PASSWORD=CHANGEME
